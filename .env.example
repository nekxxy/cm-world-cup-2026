# ─────────────────────────────────────────────────────────────
# WC26 — environment variables
# Copy to .env.local (gitignored) and fill in. The app runs fully
# from the committed seed (data/wc2026.json) even with NONE of these set.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for metadata / OG / absolute links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Data: API-Football (api-sports.io) ──────────────────────────
# Only needed to (re)generate data/wc2026.json via `npm run seed`,
# and for the optional live-score layer. Leave blank to run keyless.
API_FOOTBALL_KEY=""
# Master switch for the runtime live-score layer (false = seed only).
USE_LIVE="false"

# ── Database (Prisma) ───────────────────────────────────────────
# Dev: SQLite. Prod: swap to a Postgres connection string.
DATABASE_URL="file:./prisma/dev.db"

# ── Auth: Telegram Login ────────────────────────────────────────
# From @BotFather. BOT_USERNAME is public (used by the login widget);
# BOT_TOKEN is secret (server-only — never expose to the client).
NEXT_PUBLIC_BOT_USERNAME=""
BOT_TOKEN=""
# Secret used to sign the JWT session cookie (use: openssl rand -hex 32)
JWT_SECRET=""

# ── Notifications: Web Push (VAPID) ─────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ── Cron (kickoff reminders) ────────────────────────────────────
# Shared secret so only your scheduler can hit /api/cron/reminders.
CRON_SECRET=""
