# Set these in Vercel → Project → Settings → Environment Variables
# (and in .env.local for local dev). Restart/redeploy after changing.

# Neon Postgres connection string (pooled URL recommended for serverless).
# Neon dashboard → Connection Details → copy the "pooled" connection string.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Telegram bot token from BotFather — verifies WebApp initData AND sends bot
# messages (reminders / leaderboard). REQUIRED.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Shared secret guarding /api/check-kickoffs and /api/notify/leaderboard.
# Your external scheduler (cron-job.org / GitHub Actions) must pass it as
# ?secret=... or header x-cron-secret. REQUIRED for notifications.
CRON_SECRET=pick-a-long-random-string

# Deep-link target for bot message buttons. Defaults shown; override if your
# bot username or Mini App short name differ.
BOT_USERNAME=pocket_worldcup_bot
MINIAPP_SHORT_NAME=PocketWC
